{
  "functions": [
    {
      "source": "functions"
    }
  ],
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "**/*.@(woff2|png|jpg|jpeg|gif|svg|webp|avif|ico)",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=31536000,immutable"
          }
        ]
      },
      {
        "source": "**/*.html",
        "headers": [
          {
            "key": "Cache-Control",
            "value": "public,max-age=300"
          }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/book-appointment",
        "function": "bookAppointment"
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
